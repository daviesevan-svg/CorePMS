# Copy to .env and fill in. Loaded automatically in dev/test by config/runtime.exs;
# in production set real environment variables instead.

# Channex channel manager (https://docs.channex.io). Leave unset to disable
# the integration entirely. Use https://staging.channex.io while testing;
# switch to https://app.channex.io for production.
CHANNEX_API_KEY=
CHANNEX_BASE_URL=https://staging.channex.io
# Which rate plan (YAML id) is sold through the channel manager.
# Only one plan is synced for now.
CHANNEX_RATE_PLAN=flexible
